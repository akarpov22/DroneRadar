DATABASE_URL="postgresql://devuser:devpass@localhost:5439/dronetracker?schema=public"

# MQTT consumer (telemetry from drones via Mosquitto)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC=droneradar/telemetry/#
MQTT_CLIENT_ID=droneradar-backend

# Auth0 — AUTH0_DISABLED=true for dev without tenant
AUTH0_DISABLED=false
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.droneradar.local

# Production only (Render): comma-separated allowed browser origins.
# CORS_ORIGINS=https://droneradar.pages.dev


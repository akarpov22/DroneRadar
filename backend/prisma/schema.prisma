generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PILOT
  OBSERVER
}

model User {
  id                    String     @id @default(uuid())
  auth0Sub              String     @unique
  email                 String?
  role                  UserRole   @default(OBSERVER)
  roleOverriddenByAdmin Boolean    @default(false)
  drones                Drone[]
  userZones             UserZone[]
  createdAt             DateTime   @default(now())
}

enum UserZoneShape {
  POLYGON
  RECTANGLE
  CIRCLE
}

model UserZone {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String?
  shapeType UserZoneShape
  geometry  Json
  west      Float
  south     Float
  east      Float
  north     Float
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

model Drone {
  id              String   @id @default(uuid())
  name            String
  serial          String   @unique
  modelId         String?
  operatorId      String?
  pilotId         String?
  pilot           User?    @relation(fields: [pilotId], references: [id])
  deviceTokenHash String?
  createdAt       DateTime @default(now())
}

model DroneSession {
  id         String         @id @default(uuid())
  // drone      Drone          @relation(fields: [droneId], references: [id])
  droneId    String
  // region     Region         @relation(fields: [regionId], references: [id])
  regionId   String
  startedAt  DateTime       @default(now())
  endedAt    DateTime?
  // positions  Position[]
}

model Position {
  id         String         @id @default(uuid())
  // session    DroneSession   @relation(fields: [sessionId], references: [id])
  sessionId  String
  latitude   Float
  longitude  Float
  altitude   Float?
  speed      Float?
  heading    Float?
  recordedAt DateTime       @default(now())

  @@index([sessionId, recordedAt])
}

model Operator {
  id        String   @id @default(uuid())
  name      String
  licenseId String?  
  // drones    Drone[]
}

model DroneModel {
  id           String   @id @default(uuid())
  name         String
  manufacturer String
  maxSpeed     Float?
  maxRange     Float
  active       Boolean  @default(true)
  // drones       Drone[]
}

model Region {
  id         String   @id @default(uuid())
  name       String
  regionCode String   @unique
  active     Boolean  @default(true)
  // sessions   DroneSession[]
}

model FlightRestrictionZone {
  externalId  String   @id
  sourceLayer String
  layerType   String
  name        String?
  description String?
  lowerLimit  String?
  upperLimit  String?
  validFrom   String?
  validTo     String?
  geometry    Json
  west        Float
  south       Float
  east        Float
  north       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([layerType])
  @@index([west, east, south, north])
}

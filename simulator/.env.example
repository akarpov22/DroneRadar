# Drones — plain MQTT :1883 only (anonymous, no login/password)
MQTT_BROKER_URL=mqtt://137.66.17.57:1883

# Drone serial — only for single-drone mode (npm run single)
# In fleet mode each drone gets a unique serial: {REGION_CODE}-SIM-001, -002, ...
DRONE_SERIAL=7777MYDRONE7

# Country code (ISO 3166-1 alpha-2), required in every telemetry message
REGION_CODE=SE

# Optional: pick a specific route (0..19). Without it, route is chosen from DRONE_SERIAL hash.
# ROUTE_INDEX=0

# Simulation tuning
SIMULATION_INTERVAL_MS=500
SIMULATION_SPEED_MULTIPLIER=1
SIMULATION_SPEED_KMH=20

# Fleet launcher (npm start / npm run fleet): one unique serial per drone
# FLEET_COUNT=16
